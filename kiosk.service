[Unit]
Description=Kiosk
Wants=graphical.target
After=graphical.target
StartLimitIntervalSec=0

[Service]
Environment="DISPLAY=:0"
Environment="XDG_RUNTIME_DIR=/run/user/1000"
Environment="WAYLAND_DISPLAY=wayland-0"
Environment="DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus"
Type=simple
ExecStart=/bin/bash /home/jacklangford/jackSmartDisplay/kiosk.sh
Restart=always
RestartSec=30
KillMode=control-group
# If Linux OOM-kills a Chromium renderer or GPU child, terminate the remaining
# Chromium processes so Restart=always can relaunch a clean browser.
OOMPolicy=kill
TimeoutStopSec=10
User=jacklangford
Group=jacklangford

[Install]
WantedBy=graphical.target
